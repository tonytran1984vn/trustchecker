{
  "name": "trustchecker",
  "version": "9.5.1",
  "description": "Enterprise Digital Trust Infrastructure – Real-time QR Validation & Fraud Detection",
  "main": "server/index.js",
  "scripts": {
    "dev": "node server/index.js",
    "start": "NODE_ENV=production node server/index.js",
    "seed": "node -r dotenv/config server/seed.js",
    "test": "jest --forceExit --detectOpenHandles --coverage",
    "build:client": "cd client && npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.2",
    "@prisma/client": "^6.19.2",
    "@sentry/node": "^10.43.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.1",
    "bytenode": "^1.5.7",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "geoip-lite": "^2.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.4",
    "otplib": "^13.3.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.19.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.3",
    "stripe": "^21.0.1",
    "uuid": "^13.0.0",
    "ws": "^8.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "minimatch": ">=10.2.1",
    "glob": ">=11.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageProvider": "v8",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "server/**/*.js",
      "!server/node_modules/**"
    ],
    "testTimeout": 30000,
    "testPathIgnorePatterns": [
      "/node_modules/",
      "e2e/.*\\.spec\\.js$"
    ],
    "globalSetup": "./tests/globalSetup.js",
    "transformIgnorePatterns": [
      "node_modules/(?!(@noble|uuid|otplib|@otplib|@scure)/)"
    ],
    "transform": {
      "node_modules/(@noble|uuid|otplib|@otplib|@scure)/.+\\.js$": "babel-jest",
      "^.+\\.jsx?$": "babel-jest",
      "^.+\\.tsx?$": "babel-jest"
    }
  },
  "lint-staged": {
    "server/**/*.js": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
